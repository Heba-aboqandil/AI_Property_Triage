# Copy this file to .env and fill in your keys.
# Never commit the real .env file.

OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# Set to "gemini" to use Gemini instead of GPT-4o for the LangGraph agent
AGENT_LLM_PROVIDER=openai

# Path inside the RAG service container where the GGUF model is mounted
MODEL_PATH=/service/models/llama3.gguf
